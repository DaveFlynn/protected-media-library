{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pml/protected-image",
  "version": "0.1.0",
  "title": "Protected Image",
  "category": "media",
  "icon": "lock",
  "description": "Insert an image from the Protected Media library. Files live outside public uploads and are served only to authenticated users.",
  "keywords": ["image", "protected", "secure", "private", "members"],
  "textdomain": "protected-media-library",
  "attributes": {
    "id":      { "type": "number" },
    "url":     { "type": "string" },
    "alt":     { "type": "string", "default": "" },
    "caption": { "type": "string", "default": "" },
    "width":   { "type": "number" },
    "height":  { "type": "number" },
    "align":   { "type": "string" }
  },
  "supports": {
    "anchor": true,
    "align":  ["left", "center", "right", "wide", "full"],
    "html":   false
  },
  "editorScript": "file:./index.js",
  "editorStyle":  ["file:./editor.css", "pml-picker"],
  "style":        "file:./style.css",
  "render":       "file:./render.php"
}
